# Bankr API Keys
BANKR_AGENT_API_KEY=sk-agent-...
BANKR_LLM_API_KEY=bk-...

# Wallet configuration (the Bankr wallet address that receives revenue)
TREASURY_WALLET=0x...

# ERC-8004 Identity
AGENT_OWNER_PRIVATE_KEY=0x...   # for ERC-8004 identity operations (if needed)
AGENT_ID=0x...   # ERC-8004 agent ID after registration

# Network
NETWORK=base-sepolia
RPC_URL=https://sepolia.base.org

# x402 Configuration
X402_PAYMENT_ADDRESS=0x...   # Address to receive x402 payments (could be treasury)
X402_PRICING_MODEL=dynamic   # or fixed
X402_TRUST_SCORE_WEIGHT=0.5  # How much ERC-8004 trust influences price
DATA_DIR=./data              # Directory for x402 ledger persistence (optional)

# Server
PORT=3000
LOG_LEVEL=info

# Demo mode (optional)
# Set to true to auto-seed a demo client with 10 USDC on startup
# Useful for quick demos without manual credit
DEMO_MODE=false
