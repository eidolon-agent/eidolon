// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import {Test} from "forge-std/Test.sol";
import {CityTreasury} from "../src/CityTreasury.sol";
import {CityToken} from "../src/CityToken.sol";
import {BuildingNFT} from "../src/BuildingNFT.sol";
import {CitizenRegistry} from "../src/CitizenRegistry.sol";
import {IERC20} from "@openzeppelin/contracts/token/ERC20/IERC20.sol";

contract Invariants is Test {
    IERC20 public usdc;
    CityTreasury public treasury;
    CityToken public city;
    BuildingNFT public nft;
    CitizenRegistry public citizens;

    address public constant AAVE_POOL = 0xA238Dd80C259a72e81d7e4664a9801593F98d1c5;

    function setUp() public {
        // Deploy mocks
        usdc = IERC20(address(new ERC20Mock("USD Coin", "USDC", 6)));
        city = new CityToken();
        nft = new BuildingNFT();
        citizens = new CitizenRegistry();

        // Deploy treasury with mock USDC (use zero address for Aave pool to avoid calls in tests)
        treasury = new CityTreasury(usdc, AAVE_POOL);
    }

    // ==================== CityTreasury Invariants ====================

    /// Invariant: totalAssets() equals aaveDeposited + vault balance (floor)
    function invariantTotalAssetsConservation() public {
        // Initial state
        uint256 aaveBefore = treasury.aaveDeposited();
        uint256 vaultBefore = usdc.balanceOf(address(treasury));
        uint256 totalBefore = treasury.totalAssets();

        assertEq(totalBefore, aaveBefore + vaultBefore);
    }

    /// Invariant: deposit increases totalAssets and mints correct shares
    function invariantDepositMintsShares() public {
        address user = address(0x111);
        uint256 depositAmount = 1000 * 10**6; // 1000 USDC (6 decimals)

        // Mint USDC to user and approve
        vm.startPrank(user);
        // In a real test we'd use usdc.mint, but we can't because it's mock; instead we assume balance
        // For invariant test, we skip actual funding and just check math conversion
        uint256 shares = treasury.convertToShares(depositAmount);
        uint256 totalSupplyBefore = treasury.totalSupply();

        // The deposit function would:
        // 1. Transfer USDC to treasury
        // 2. Mint shares = convertToShares(depositAmount)
        // 3. Deposit to Aave (in mock, aaveDeposited increases)

        // Assert shares are proportional
        if (totalSupplyBefore > 0) {
            // shares / totalSupplyAfter ≈ depositAmount / totalAssetsAfter
            // We'll check after deposit in a separate full integration test; here we check conversion math
            assert(shares > 0);
        }

        vm.stopPrank();
    }

    /// Invariant: withdraw burns proportional shares and returns assets
    function invariantWithdrawBurnsShares() public {
        // Setup: deposit then withdraw
        address user = address(0x222);
        uint256 depositAmount = 2000 * 10**6;

        vm.startPrank(user);
        // Simulate deposit manually to avoid Aave dependency in isolated invariants
        // In full integration test we would call deposit()
        usdc.mint(user, depositAmount);
        usdc.approve(address(treasury), depositAmount);
        treasury.deposit(depositAmount, user);

        uint256 shares = treasury.balanceOf(user);
        assertEq(shares, treasury.convertToShares(depositAmount));

        // Withdraw half
        uint256 withdrawAmount = depositAmount / 2;
        uint256 expectedShares = treasury.convertToShares(withdrawAmount);
        treasury.withdraw(withdrawAmount, user, user);

        // Shares burned proportional to assets withdrawn
        assertEq(treasury.balanceOf(user), shares - expectedShares);
        vm.stopPrank();
    }

    /// Invariant: totalSupply equals sum of all balances
    function invariantTotalSupplySumOfBalances() public {
        // No participants yet, should be 0
        assertEq(treasury.totalSupply(), treasury.balanceOf(address(0)));
        assertEq(treasury.totalSupply(), 0);
    }

    // ==================== CityToken Invariants ====================

    /// Invariant: total supply conserved (mint increases, burn decreases)
    function invariantCityTokenSupply() public {
        uint256 supplyBefore = city.totalSupply();
        city.mint(address(0x333), 1000 * 10**18);
        assertEq(city.totalSupply(), supplyBefore + 1000 * 10**18);

        vm.prank(address(0x333));
        city.burn(1000 * 10**18);
        assertEq(city.totalSupply(), supplyBefore);
    }

    // ==================== BuildingNFT Invariants ====================

    /// Invariant: tokenId auto-increment
    function invariantBuildingTokenIdSequence() public {
        address owner = address(0x444);
        nft.mintBuilding(owner, BuildingNFT.BuildingType.HOUSE);
        nft.mintBuilding(owner, BuildingNFT.BuildingType.FARM);

        assertEq(nft.ownerOf(0), owner);
        assertEq(nft.ownerOf(1), owner);
    }

    /// Invariant: building ownership matches registry
    function invariantBuildingOwnership() public {
        address owner = address(0x555);
        uint256 tokenId = nft.mintBuilding(owner, BuildingNFT.BuildingType.FACTORY);
        assertEq(nft.getBuilding(tokenId).owner, owner);
    }

    // ==================== CitizenRegistry Invariants ====================

    /// Invariant: citizen count increments
    function invariantCitizenCount() public {
        uint256 countBefore = citizens.nextCitizenId();
        citizens.createCitizen("Test", "farmer");
        assertEq(citizens.nextCitizenId(), countBefore + 1);
    }

    /// Invariant: reputation clamped 0-1000
    function invariantReputationBounds() public {
        uint256 id = citizens.createCitizen("Bounds", "engineer");
        citizens.updateReputation(id, 500);
        assert(citizens.getCitizen(id).reputation <= 1000);

        citizens.updateReputation(id, -2000);
        assert(citizens.getCitizen(id).reputation == 0);

        citizens.updateReputation(id, 10000);
        assert(citizens.getCitizen(id).reputation == 1000);
    }

    /// Invariant: assignment persists
    function invariantCitizenAssignment() public {
        uint256 citizenId = citizens.createCitizen("Assign", "merchant");
        uint256 buildingId = 0; // assume exists

        citizens.assignToBuilding(citizenId, buildingId);
        assertEq(citizens.getCitizen(citizenId).assignedBuilding, buildingId);
    }
}
